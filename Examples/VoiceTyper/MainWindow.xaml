<Window x:Class="VoiceTyper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="VoxType"
        Width="540" Height="588"
        MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#12141A"
        Foreground="#E6E9F0"
        FontFamily="Segoe UI" FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="Bg" Color="#12141A"/>
        <SolidColorBrush x:Key="Surface" Color="#1C1F28"/>
        <SolidColorBrush x:Key="Surface2" Color="#222633"/>
        <SolidColorBrush x:Key="Input" Color="#20232C"/>
        <SolidColorBrush x:Key="Border" Color="#333A49"/>
        <SolidColorBrush x:Key="Text" Color="#E6E9F0"/>
        <SolidColorBrush x:Key="Dim" Color="#8A90A2"/>
        <SolidColorBrush x:Key="Accent" Color="#7C5CFF"/>
        <SolidColorBrush x:Key="Green" Color="#3DD17A"/>

        <!-- Vector icon geometries -->
        <Geometry x:Key="GeoCube">M12,3 L20,7.5 L20,16.5 L12,21 L4,16.5 L4,7.5 Z M4,7.5 L12,12 L20,7.5 M12,12 L12,21</Geometry>
        <Geometry x:Key="GeoChip">M7,7 H17 V17 H7 Z M10,10 H14 V14 H10 Z M9,7 V4 M12,7 V4 M15,7 V4 M9,17 V20 M12,17 V20 M15,17 V20 M7,9 H4 M7,12 H4 M7,15 H4 M17,9 H20 M17,12 H20 M17,15 H20</Geometry>

        <!-- Dark scrollbars -->
        <Style x:Key="ScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="t" Background="#3A4150" CornerRadius="5" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="t" Property="Background" Value="#4C5468"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="11"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Glyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Read-only value field (model path, GPU, input/output) -->
        <Style x:Key="ValueBox" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Input}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="12,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Window caption buttons -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Dim}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2A2F3C"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E03A4E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button (folder, reload, clear) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2C313E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#373E4E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small pill button (Очистити) -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2C313E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded ComboBox -->
        <Style x:Key="ComboToggle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="{StaticResource Input}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"/>
                            <ToggleButton Style="{StaticResource ComboToggle}" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="cp" Margin="12,0,32,0" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"/>
                            <TextBlock Style="{StaticResource Glyph}" Text="&#xE70D;" FontSize="11"
                                       Foreground="{StaticResource Dim}" HorizontalAlignment="Right"
                                       Margin="0,0,12,0" IsHitTestVisible="False"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource Surface2}" BorderBrush="{StaticResource Border}"
                                        BorderThickness="1" CornerRadius="8" Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.5" Color="Black"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="280">
                                        <ItemsPresenter Margin="4"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#34394A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#3A3170"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="box" Width="18" Height="18" CornerRadius="5"
                                    Background="{StaticResource Input}" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                <TextBlock x:Name="chk" Style="{StaticResource Glyph}" Text="&#xE73E;" FontSize="11"
                                           Foreground="White" HorizontalAlignment="Center" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Bg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="14,0,6,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Rectangle Width="3" Height="11" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource Accent}" Margin="0,0,2,0"/>
                        <Rectangle Width="3" Height="17" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource Accent}" Margin="0,0,2,0"/>
                        <Rectangle Width="3" Height="8" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource Accent}" Margin="0,0,2,0"/>
                        <Rectangle Width="3" Height="14" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource Accent}"/>
                    </StackPanel>
                    <TextBlock Text="VoxType" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnMin" Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="BtnMin_Click"/>
                    <Button x:Name="BtnClose" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16,2,16,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="142"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Model -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                        <Path Data="{StaticResource GeoCube}" Stroke="{StaticResource Accent}" StrokeThickness="1.6" StrokeLineJoin="Round" Width="17" Height="17" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Style="{StaticResource RowLabel}" Text="Модель"/>
                    </StackPanel>
                    <Grid Grid.Row="0" Grid.Column="1" Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource ValueBox}">
                            <TextBlock x:Name="TxtModel" Style="{StaticResource ValueText}" Foreground="#D9D4FF"/>
                        </Border>
                        <Button x:Name="BtnBrowse" Grid.Column="1" Style="{StaticResource IconButton}" Content="&#xE8DA;" Margin="6,0,0,0" Click="BtnBrowse_Click" ToolTip="Вибрати файл моделі"/>
                        <Button x:Name="BtnReload" Grid.Column="2" Style="{StaticResource IconButton}" Content="&#xE72C;" Margin="6,0,0,0" Click="BtnReload_Click" ToolTip="Перезавантажити"/>
                    </Grid>

                    <TextBlock x:Name="LblModelInfo" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource Dim}" FontSize="11.5" Margin="2,0,0,0"/>

                    <!-- Microphone -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE720;" FontSize="16" Foreground="{StaticResource Accent}" Margin="0,0,10,0"/>
                        <TextBlock Style="{StaticResource RowLabel}" Text="Мікрофон"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbDevice" Grid.Row="3" Grid.Column="1" Style="{StaticResource RoundCombo}" Margin="0,3"/>

                    <!-- GPU -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                        <Path Data="{StaticResource GeoChip}" Stroke="{StaticResource Accent}" StrokeThickness="1.6" StrokeLineJoin="Round" Width="17" Height="17" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Style="{StaticResource RowLabel}" Text="Відеокарта"/>
                    </StackPanel>
                    <Border Grid.Row="4" Grid.Column="1" Margin="0,3" Style="{StaticResource ValueBox}">
                        <TextBlock x:Name="TxtGpuName" Style="{StaticResource ValueText}" Foreground="#D9D4FF" Text="—"/>
                    </Border>

                    <!-- Language -->
                    <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE774;" FontSize="16" Foreground="{StaticResource Accent}" Margin="0,0,10,0"/>
                        <TextBlock Style="{StaticResource RowLabel}" Text="Мова"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbLang" Grid.Row="5" Grid.Column="1" Style="{StaticResource RoundCombo}" Margin="0,3"/>

                    <!-- Insert -->
                    <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE765;" FontSize="16" Foreground="{StaticResource Accent}" Margin="0,0,10,0"/>
                        <TextBlock Style="{StaticResource RowLabel}" Text="Вставка тексту"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbInsert" Grid.Row="6" Grid.Column="1" Style="{StaticResource RoundCombo}" Margin="0,3"/>

                    <!-- Hotkey -->
                    <StackPanel Grid.Row="7" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE92E;" FontSize="16" Foreground="{StaticResource Accent}" Margin="0,0,10,0"/>
                        <TextBlock Style="{StaticResource RowLabel}" Text="Клавіша"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbHotkey" Grid.Row="7" Grid.Column="1" Style="{StaticResource RoundCombo}" Margin="0,3" SelectionChanged="CmbHotkey_SelectionChanged"/>

                    <!-- Checkboxes -->
                    <StackPanel Grid.Row="8" Grid.Column="1" Margin="0,5,0,0">
                        <CheckBox x:Name="ChkSpace" Margin="0,2" Content="Додавати пробіл після тексту"/>
                        <CheckBox x:Name="ChkSwallow" Margin="0,2" Content="Перехоплювати клавішу (не передавати)" Checked="ChkSwallow_Changed" Unchecked="ChkSwallow_Changed"/>
                        <CheckBox x:Name="ChkAutostart" Margin="0,2" Content="Запускати при старті Windows" Checked="ChkAutostart_Changed" Unchecked="ChkAutostart_Changed"/>
                    </StackPanel>

                    <!-- Input: audio/video file to transcribe -->
                    <StackPanel Grid.Row="10" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE767;" FontSize="16" Foreground="{StaticResource Accent}" Margin="0,0,10,0"/>
                        <TextBlock Style="{StaticResource RowLabel}" Text="Input"/>
                    </StackPanel>
                    <Grid Grid.Row="10" Grid.Column="1" Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource ValueBox}"
                                AllowDrop="True" DragOver="Input_DragOver" Drop="Input_Drop">
                            <TextBlock x:Name="TxtInput" Style="{StaticResource ValueText}" Foreground="{StaticResource Dim}" Text="Виберіть або перетягніть файли"/>
                        </Border>
                        <Button x:Name="BtnInputBrowse" Grid.Column="1" Style="{StaticResource IconButton}" Content="&#xE8B7;" Margin="6,0,0,0" Click="BtnInputBrowse_Click" ToolTip="Вибрати аудіо/відео файл"/>
                    </Grid>

                    <!-- Output: folder to save the .txt transcript -->
                    <StackPanel Grid.Row="11" Grid.Column="0" Orientation="Horizontal" Margin="0,3">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE8A5;" FontSize="16" Foreground="{StaticResource Accent}" Margin="0,0,10,0"/>
                        <TextBlock Style="{StaticResource RowLabel}" Text="Output"/>
                    </StackPanel>
                    <Grid Grid.Row="11" Grid.Column="1" Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource ValueBox}">
                            <TextBlock x:Name="TxtOutput" Style="{StaticResource ValueText}" Foreground="{StaticResource Dim}" Text="Виберіть папку для збереження"/>
                        </Border>
                        <Button x:Name="BtnOutputBrowse" Grid.Column="1" Style="{StaticResource IconButton}" Content="&#xE8B7;" Margin="6,0,0,0" Click="BtnOutputBrowse_Click" ToolTip="Вибрати папку для збереження .txt"/>
                    </Grid>
                </Grid>

                <!-- Status banner -->
                <Border Grid.Row="1" Background="{StaticResource Surface}" CornerRadius="10" Padding="12,8" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="22" Height="22" Margin="0,0,10,0">
                            <Ellipse x:Name="StatusDotBig" Fill="{StaticResource Green}"/>
                            <TextBlock x:Name="StatusIcon" Style="{StaticResource Glyph}" Text="&#xE73E;" FontSize="11" Foreground="White" HorizontalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="TxtStatus" VerticalAlignment="Center" FontSize="13.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Green}" Text="Завантажте модель…"/>
                    </StackPanel>
                </Border>

                <!-- Log card -->
                <Border Grid.Row="2" Background="{StaticResource Surface}" CornerRadius="10" Padding="12,8" Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource Glyph}" Text="&#xE8A5;" FontSize="14" Foreground="{StaticResource Dim}" Margin="0,0,8,0"/>
                                <TextBlock Text="Журнал розпізнавання" FontWeight="SemiBold" Foreground="{StaticResource Dim}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnClear" Style="{StaticResource PillButton}" Click="BtnClear_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE74D;" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Очистити"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnCollapse" Style="{StaticResource IconButton}" Width="32" Height="28" Margin="6,0,0,0" Content="&#xE70E;" FontSize="11" Click="BtnCollapse_Click"/>
                            </StackPanel>
                        </Grid>
                        <TextBox x:Name="TxtLog" Grid.Row="1" Margin="0,8,0,0" Background="Transparent"
                                 Foreground="{StaticResource Text}" BorderThickness="0" IsReadOnly="True"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="12.5"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom status bar -->
            <Border Grid.Row="2" Background="#0E1015" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDotSmall" Width="8" Height="8" Fill="{StaticResource Green}" Margin="0,0,7,0"/>
                        <TextBlock x:Name="TxtBottom" Text="Готово" Foreground="{StaticResource Dim}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Path Data="{StaticResource GeoChip}" Stroke="{StaticResource Dim}" StrokeThickness="1.6" StrokeLineJoin="Round" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="TxtGpu" Text="GPU: —" Foreground="{StaticResource Dim}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
